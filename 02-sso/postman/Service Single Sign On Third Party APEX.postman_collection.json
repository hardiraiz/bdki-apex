					"name": "Get Acces Token Copy",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Save signature token\", function () {",
									"    var jsonData = pm.response.json();",
									"    console.log(jsonData)",
									"    pm.environment.set(\"ACCESS_TOKEN\", jsonData.result.access_token); // Store in environment variable",
									"    // pm.globals.set(\"SIGNATURE_TOKEN\", jsonData.result);",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Define the character set for alphanumeric characters",
									"const characters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';",
									"const charactersLength = characters.length;",
									"",
									"// Initialize an empty string to hold the random string",
									"let randomString = '';",
									"",
									"// Loop 16 times to generate a 16-character string",
									"for (let i = 0; i < 16; i++) {",
									"    // Generate a random index to pick a character from the character set",
									"    const randomIndex = Math.floor(Math.random() * charactersLength);",
									"    // Append the selected character to the randomString",
									"    randomString += characters.charAt(randomIndex);",
									"}",
									"",
									"// Store the generated random string in a Postman environment variable named 'randomString'",
									"pm.environment.set(\"RAY-ID\", randomString);",
									"",
									"// Optional: Log the generated random string to the console for verification",
									"console.log(\"Generated Random String:\", randomString);",
									""
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
